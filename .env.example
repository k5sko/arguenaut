# Copy to .env and fill in.

# Groq API key for perspective generation + axis labeling
GROQ_API_KEY=

# Groq model used for generation/labeling
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace model ID for activation extraction
HF_MODEL_ID=Qwen/Qwen2.5-3B

# Lambda backend URL (FastAPI server, see arguenaut/app/lambda_server.py)
# Used by the Streamlit app for live activation extraction.
# When you run `arguenaut-lambda up`, this is auto-populated in data/.lambda-state.json,
# and the --remote flag on scripts uses that automatically. You only set this manually
# if you're pointing at a server you started yourself.
LAMBDA_API_URL=http://localhost:8000
LAMBDA_API_TOKEN=

# ── Lambda Cloud auto-provisioning ────────────────────────────────────────────
# Needed by `arguenaut-lambda up/down/status`.
LAMBDA_CLOUD_API_KEY=                      # get from cloud.lambda.ai → Account → API keys
LAMBDA_SSH_KEY_NAME=                       # name of the SSH key you registered in the Lambda console
LAMBDA_SSH_KEY_PATH=~/.ssh/id_rsa          # local path to the matching private key
LAMBDA_INSTANCE_TYPE=gpu_1x_a10            # gpu_1x_a10 (24GB) is the cheapest option that fits 4B fp16
LAMBDA_REGION=                             # leave blank to auto-pick a region with capacity
LAMBDA_FILE_SYSTEM_NAME=                   # optional persistent FS for HF model cache (created once in the console)
LAMBDA_GIT_URL=                            # https://github.com/<you>/arguenaut.git  (required for bootstrap)
LAMBDA_GIT_REF=main                        # branch / tag / commit to deploy
LAMBDA_AUTO_SHUTDOWN_MINUTES=15            # server self-terminates after this many idle minutes

# Data paths (relative to project root)
ARGUENAUT_DATA_DIR=data
ARGUENAUT_DB_PATH=data/arguenaut.sqlite
ARGUENAUT_HDF5_PATH=data/activations.h5
